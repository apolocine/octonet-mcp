# OctoNet MCP — Production (mcp.amia.fr)
# Author: Dr Hamid MADANI drmdh@msn.com

# Database — SQLite en memoire pour la demo publique
DB_DIALECT=sqlite
SGBD_URI=:memory:
DB_SCHEMA_STRATEGY=create
DB_SHOW_SQL=false

# Port interne (Apache reverse proxy → ce port)
MOSTA_NET_PORT=14500

# Transports actives
MOSTA_NET_REST_ENABLED=true
MOSTA_NET_GRAPHQL_ENABLED=true
MOSTA_NET_WS_ENABLED=true
MOSTA_NET_SSE_ENABLED=true
MOSTA_NET_JSONRPC_ENABLED=true
MOSTA_NET_MCP_ENABLED=true
MOSTA_NET_TRPC_ENABLED=true
MOSTA_NET_ODATA_ENABLED=true

# Transports desactives (pas de serveur NATS/gRPC en prod pour l'instant)
MOSTA_NET_GRPC_ENABLED=false
MOSTA_NET_NATS_ENABLED=false
MOSTA_NET_ARROW_ENABLED=false

# CORS — autoriser Smithery et Claude Desktop
MOSTA_NET_CORS_ORIGIN=*
